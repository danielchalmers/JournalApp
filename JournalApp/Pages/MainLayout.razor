@namespace JournalApp
@inherits LayoutComponentBase
@implements IDisposable
@inject KeyEventService KeyEventService
@inject PreferenceService PreferenceService
@inject ILogger<MainLayout> logger

<MudThemeProvider Theme="_theme" IsDarkMode="PreferenceService.IsDarkMode" DefaultScrollbar />

<MudPopoverProvider />

<MudDialogProvider MaxWidth="MaxWidth.Small"
                   FullWidth="true"
                   NoHeader="false"
                   CloseButton="false"
                   CloseOnEscapeKey="false"
                   Position="DialogPosition.Center" />

<MudSnackbarProvider />

<div class="page">
    @Body
</div>

@code {
    bool _hasInitiallyRendered;

    MudTheme _theme = new()
    {
        // "Orchid" Material 3 tonal palette, seed #854C73.
        // Background = M3 surface, Surface = M3 surfaceContainer (cards),
        // Darken = onContainer, Lighten = container.
        PaletteLight = new PaletteLight()
        {
            Primary = "#854C73",
            PrimaryContrastText = "#FFFFFF",
            PrimaryDarken = "#6B355A",
            PrimaryLighten = "#FFD8EA",
            Secondary = "#715867",
            SecondaryContrastText = "#FFFFFF",
            SecondaryDarken = "#58414F",
            SecondaryLighten = "#FBDAEA",
            Tertiary = "#7F5539",
            TertiaryContrastText = "#FFFFFF",
            TertiaryDarken = "#64392A",
            TertiaryLighten = "#FFDBCA",
            Error = "#A8364B",
            Background = "#FFF8F9",
            Surface = "#FCEAF0",
            AppbarBackground = "#FFF8F9",
            AppbarText = "#211A1E",
            TextPrimary = "#211A1E",
            TextSecondary = "#504349",
            LinesDefault = "#D4C2C9",
            Divider = "#D4C2C9",
            TableLines = "#D4C2C9",

            HoverOpacity = 0.1,
        },

        PaletteDark = new PaletteDark()
        {
            Primary = "#F8B2D9",
            PrimaryContrastText = "#4F2242",
            PrimaryDarken = "#6B355A",
            PrimaryLighten = "#FFD8EA",
            Secondary = "#DEBED0",
            SecondaryContrastText = "#41303C",
            SecondaryDarken = "#58414F",
            SecondaryLighten = "#FBDAEA",
            Tertiary = "#F5BB98",
            TertiaryContrastText = "#4A2511",
            TertiaryDarken = "#64392A",
            TertiaryLighten = "#FFDBCA",
            Error = "#F97386",
            Background = "#181114",
            Surface = "#251D21",
            AppbarBackground = "#181114",
            AppbarText = "#EEDFE4",
            TextPrimary = "#EEDFE4",
            TextSecondary = "#D4C2C9",
            LinesDefault = "#504349",
            Divider = "#504349",
            TableLines = "#504349",

            HoverOpacity = 0.1,
        },

        LayoutProperties = new()
        {
            DefaultBorderRadius = "8px",
        },

        Typography = new()
        {
            Button = new ButtonTypography()
            {
                TextTransform = "none",
            },

            Caption = new CaptionTypography()
            {
                LineHeight = "1",
            },
        },
    };

    protected override void OnInitialized()
    {
        base.OnInitialized();

        PreferenceService.ThemeChanged += OnThemeChanged;

        if (App.Window is not null) // Not available in tests.
        {
            App.Window.Destroying += (_, _) => Dispose();
        }

        // All pages have been reloaded so we should clear any leftover subscriptions.
        KeyEventService.ResetStack();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _hasInitiallyRendered = true;
            logger.LogInformation("Blazor layout first render completed");
        }
    }

    public void OnThemeChanged(object sender, bool isDarkMode)
    {
        if (_hasInitiallyRendered)
            StateHasChanged();
    }

    public void Dispose()
    {
        PreferenceService.ThemeChanged -= OnThemeChanged;
    }
}
