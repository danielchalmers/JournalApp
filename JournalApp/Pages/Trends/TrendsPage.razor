@namespace JournalApp
@page "/trends/{OpenToDateString}"
@using CommunityToolkit.Maui.Storage;
@inherits JaPage
@implements IDisposable
@inject ILogger<TrendsPage> logger
@inject IDbContextFactory<AppDbContext> DbFactory

<header class="page-header">
    <div class="page-toolbar">
        <MudIconButton Icon="@Icons.Material.Rounded.ArrowBack" aria-label="Go home" OnClick="Close" />

        <MudText Typo="Typo.h6">Trends</MudText>
    </div>

    <TrendsSwitcher @bind-SelectedDates="SelectedDates" @bind-SelectedDates:after="LoadDates" OpenToDate="OpenToDate" />
</header>

<main class="page-body">
    <div id="trends-category-list">
        @foreach (var item in CategoryItems)
        {
            var category = item.Category;

            @if (category.Group == "Notes" && Preferences.Get("hide_notes", false))
            {
                continue;
            }

            <section class="trends-category">
                <MudText Class="list-group-title">@(TrendCategoryView.GetHeaderText(category))</MudText>

                <ErrorBoundary>
                    <ChildContent>
                        <TrendCategoryView Category="category" Dates="SelectedDates" PointsByDay="item.PointsByDay" />
                    </ChildContent>

                    <ErrorContent>
                        <MudText Color="Color.Error">💥 Failed to load.</MudText>
                    </ErrorContent>
                </ErrorBoundary>
            </section>
        }

        @if (_isLoading)
        {
            <MudText Typo="Typo.caption">Loading more trends...</MudText>
        }
    </div>
</main>

@code {
    const int CategoryBatchSize = 4;

    [Parameter]
    public string OpenToDateString { get; set; }

    public DateOnly OpenToDate { get; set; }

    public IReadOnlyList<DateOnly> SelectedDates { get; set; }

    List<TrendCategoryItem> CategoryItems = [];
    CancellationTokenSource _loadCts;
    bool _isLoading;

    protected override void OnInitialized()
    {
        logger.LogDebug("Initializing");
        base.OnInitialized();

        KeyEventService.Entered(() => Close());

        OpenToDate = DateOnly.ParseExact(OpenToDateString, "yyyyMMdd");
        logger.LogInformation("Opening trends to {OpenToDate}", OpenToDate);
    }

    async Task LoadDates()
    {
        if (SelectedDates == null || SelectedDates.Count == 0)
            return;

        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = new();

        var currentLoad = _loadCts;
        var cancellationToken = currentLoad.Token;
        logger.LogInformation("Loading trends for {StartDate}..{EndDate}", SelectedDates[0], SelectedDates[^1]);
        var sw = Stopwatch.StartNew();
        var startDate = SelectedDates[0];
        var endDate = SelectedDates[^1];
        var selectedDates = SelectedDates.ToArray();

        CategoryItems.Clear();
        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(cancellationToken);

            var categoryGuids = await db.Points
                .Where(p => !p.Deleted && !p.Category.Deleted && p.Category.Enabled && p.Day.Date >= startDate && p.Day.Date <= endDate)
                .Select(p => p.Category.Guid)
                .Distinct()
                .ToListAsync(cancellationToken);

            var categories = await db.Categories
                .Where(c => categoryGuids.Contains(c.Guid))
                .OrderBy(c => c.Group)
                .ThenBy(c => c.Index)
                .ToListAsync(cancellationToken);

            for (var i = 0; i < categories.Count; i += CategoryBatchSize)
            {
                cancellationToken.ThrowIfCancellationRequested();

                var batchCategories = categories.Skip(i).Take(CategoryBatchSize).ToList();
                var batchCategoryGuids = batchCategories.Select(x => x.Guid).ToList();

                var points = await db.Points
                    .Where(
                        p => !p.Deleted
                             && !p.Category.Deleted
                             && p.Category.Enabled
                             && p.Day.Date >= startDate
                             && p.Day.Date <= endDate
                             && batchCategoryGuids.Contains(p.Category.Guid)
                    )
                    .Include(p => p.Category)
                    .Include(p => p.Day)
                    .OrderBy(p => p.Day.Date)
                    .ThenBy(p => p.CreatedAt)
                    .ToListAsync(cancellationToken);

                var pointsLookup = points
                    .GroupBy(p => p.Category.Guid)
                    .ToDictionary(g => g.Key, g => g.ToLookup(p => p.Day.Date));

                foreach (var category in batchCategories)
                {
                    pointsLookup.TryGetValue(category.Guid, out var categoryLookup);
                    var pointsByDate = selectedDates.ToDictionary(
                        date => date,
                        date => (IReadOnlyCollection<DataPoint>)(categoryLookup?[date].ToArray() ?? Array.Empty<DataPoint>())
                    );

                    CategoryItems.Add(new(category, pointsByDate));
                }

                await InvokeAsync(StateHasChanged);

                if (i + CategoryBatchSize < categories.Count)
                    await Task.Yield();
            }
        }
        catch (OperationCanceledException)
        {
            logger.LogDebug("Cancelled trends load");
            return;
        }
        finally
        {
            if (ReferenceEquals(_loadCts, currentLoad))
            {
                _isLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }

        sw.Stop();
        logger.LogInformation("Loaded trends data in {ElapsedMilliseconds}ms (categories: {CategoryCount})", sw.ElapsedMilliseconds, CategoryItems.Count);
    }

    void Close()
    {
        logger.LogInformation("Going to index");
        NavigationManager.NavigateTo("/", false, true);
    }

    protected override void Dispose(bool disposing)
    {
        logger.LogDebug("Disposing");
        base.Dispose(disposing);

        _loadCts?.Cancel();
        _loadCts?.Dispose();
        KeyEventService.Exited();
    }

    public readonly record struct TrendCategoryItem(
        DataPointCategory Category,
        IReadOnlyDictionary<DateOnly, IReadOnlyCollection<DataPoint>> PointsByDay
    );
}
