    [Theory]
    [InlineData("oz", 10d, null, "Hi 10oz:")]
    [InlineData("oz", 10d, 20d, "Hi 20oz*:")]
    [InlineData("oz", null, null, "Hi:")]
    [InlineData("oz", null, 20d, "Hi 20oz*:")]
    [InlineData(null, 10d, null, "Hi:")]
    [InlineData(null, 10d, 20d, "Hi:")]
    public void HeaderMedication_WithDoseAndUnitCombinations(string unit, double? categoryDose, double? pointDose, string expectedHeader)
    {
        var category = new DataPointCategory
        {
            Guid = Guid.NewGuid(),
            Name = "Hi",
            Type = PointType.Medication,
            MedicationUnit = unit,
            MedicationDose = categoryDose.HasValue ? (decimal?)categoryDose.Value : null,
        };

        var day = Day.Create(new(2024, 01, 01));
        var point = DataPoint.Create(day, category);

        if (pointDose.HasValue)
        {
            point.MedicationDose = (decimal)pointDose.Value;
        }

        DataPointView.GetHeaderText(point).Should().Be(expectedHeader);
    }
