    [Fact]
    public async Task EditDialog_Delete()
    {
        var dbf = Services.GetService<IDbContextFactory<AppDbContext>>();
        var guid = "de394b38-9007-4349-ae31-429541aab947"; // Physical activity.
        var categoryGuid = new Guid(guid);

        // Ensure this category has an existing point so deletion validates point cleanup too.
        using (var db = dbf.CreateDbContext())
        {
            var category = db.Categories.Single(c => c.Guid == categoryGuid);
            var day = Day.Create(new DateOnly(2024, 1, 1));
            db.Days.Add(day);
            db.Points.Add(DataPoint.Create(day, category));
            db.SaveChanges();
        }

        var layout = Render(
    @<MainLayout>
        <Body>
            <ManageCategoriesPage />
        </Body>
    </MainLayout>
        );

        var initialCount = layout.FindAll(".manage-category-edit-button").Count;

        await layout.Find($"#manage-category-{guid} > .manage-category-edit-button").ClickAsync();
        layout.WaitForAssertion(() => layout.HasComponent<EditCategoryDialog>().Should().BeTrue());

        await layout.Find(".category-dialog .delete-button").ClickAsync();
        layout.WaitForAssertion(() => layout.Find(".mud-message-box__yes-button"));
        await layout.Find(".mud-message-box__yes-button").ClickAsync();

        layout.WaitForAssertion(() => layout.HasComponent<EditCategoryDialog>().Should().BeFalse());
        layout.WaitForAssertion(() => layout.FindAll(".manage-category-edit-button").Count.Should().Be(initialCount - 1));

        using (var db = dbf.CreateDbContext())
        {
            db.Categories.Single(c => c.Guid == categoryGuid).Deleted.Should().BeTrue();
            db.Points.Any(p => p.Category.Guid == categoryGuid).Should().BeFalse();
        }
    }

    [Fact]
    public async Task AddNewCategory()
    {
        var layout = Render(
    @<MainLayout>
        <Body>
            <ManageCategoriesPage />
        </Body>
    </MainLayout>
        );

        var initialCount = layout.FindAll(".manage-category-edit-button").Count;

        // Open the dialog to create a new category.
        await layout.Find(".add-category-button").ClickAsync();
        layout.Markup.Should().Contain("New element");

        // Set up the new category.
        layout.FindAll(".category-dialog .mud-input-text input")[0].Input("New name");

        // Submit changes and confirm there is a new category in the list.
        await layout.Find(".category-dialog .submit-button").ClickAsync();
        layout.FindAll(".manage-category-edit-button").Count.Should().Be(initialCount + 1);
    }

