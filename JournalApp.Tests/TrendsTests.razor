@namespace JournalApp.Tests
@inherits JaTestContext

@code {
    [Fact]
    public void HeaderCategory()
    {
        var category = new DataPointCategory
        {
            Guid = Guid.NewGuid(),
            Name = "Hello World",
            Type = PointType.Text,
        };

        TrendCategoryView.GetHeaderText(category).Should().Be("Hello World");
    }

    [Fact]
    public void HeaderCategory_FallbackToGroupName()
    {
        var category = new DataPointCategory
        {
            Guid = Guid.NewGuid(),
            Group = "Notes",
            Type = PointType.Note,
        };

        TrendCategoryView.GetHeaderText(category).Should().Be("Notes");
    }

    [Theory]
    [InlineData("oz", "Hi (oz)")]
    [InlineData("  oz", "Hi (oz)")]
    [InlineData(null, "Hi")]
    public void HeaderMedication_WithDifferentUnits(string unit, string expectedHeader)
    {
        var category = new DataPointCategory
        {
            Guid = Guid.NewGuid(),
            Name = "Hi",
            Type = PointType.Medication,
            MedicationUnit = unit,
        };

        TrendCategoryView.GetHeaderText(category).Should().Be(expectedHeader);
    }
}
